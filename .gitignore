.claude/*
!.claude/settings.json
.qwen/*
!.qwen/settings.json
*.stackdump
__pycache__/
*.pyc

.maintenance.json

# Dev-tooling deps (aislop) — pinned via package.json + package-lock.json,
# installed with `npm ci --ignore-scripts`; the tree itself is not committed.
node_modules/

# aislop per-run artifacts (session/history logs; .aislop/config.yml stays tracked)
.aislop/*.jsonl

# coverage.py data files (the 100% gate runs in CI; local runs leave these behind)
.coverage
.coverage.*

# pytest cache (no pytest suite; stray runs still drop it)
.pytest_cache/
